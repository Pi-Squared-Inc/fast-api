{
  "name": "fast-api",
  "version": "0.1.0",
  "description": "Fast chain SDK and API platform",
  "type": "module",
  "workspaces": [
    "sdk/fast-sdk",
    "sdk/allset-sdk",
    "sdk/x402-server"
  ],
  "scripts": {
    "predev": "npm run build:sdk",
    "dev": "next dev",
    "prebuild": "npm run build:sdk",
    "build": "next build",
    "prestart": "npm run build:sdk",
    "start": "next start",
    "build:sdk": "npm run build:fast-sdk && npm run build:allset-sdk && npm run build:x402-server",
    "build:fast-sdk": "tsc -p sdk/fast-sdk/tsconfig.json",
    "build:allset-sdk": "tsc -p sdk/allset-sdk/tsconfig.json",
    "build:x402-server": "tsc -p sdk/x402-server/tsconfig.json",
    "clean:sdk": "rm -rf sdk/fast-sdk/dist sdk/allset-sdk/dist sdk/x402-server/dist",
    "test:fast-sdk": "node --import tsx --test sdk/fast-sdk/tests/*.test.ts",
    "test:x402-server": "node --import tsx --test sdk/x402-server/tests/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Pi2Labs",
  "license": "UNLICENSED",
  "dependencies": {
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
